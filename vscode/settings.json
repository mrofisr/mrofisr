{
    "workbench.startupEditor": "none",
    
    // Theme Configuration (Everforest Dark Medium)
    "workbench.colorTheme": "Everforest Dark",
    "editor.semanticHighlighting.enabled": true,
    
    // Focus Settings (Minimizing distractions)
    "editor.minimap.enabled": false,
    "workbench.activityBar.location": "hidden",
    "workbench.statusBar.visible": false,
    "breadcrumbs.enabled": false,
    "editor.scrollbar.horizontal": "hidden",
    "editor.hideCursorInOverviewRuler": true,
    "editor.overviewRulerBorder": false,
    "editor.renderLineHighlight": "gutter",
    
    // Geek Settings (Productivity, advanced styling & privacy)
    "editor.fontFamily": "'MesloLGM Nerd Font', Menlo, Monaco, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.renderWhitespace": "all",
    "editor.guides.indentation": true,
    "editor.guides.bracketPairs": "active",
    "editor.inlayHints.enabled": "on",
    "editor.rulers": [
        80,
        120
    ],
    "editor.lineNumbers": "relative",
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "block",
    "terminal.integrated.smoothScrolling": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "telemetry.telemetryLevel": "off",
    
    // Zen Mode Behavior
    "zenMode.fullScreen": true,
    "zenMode.hideActivityBar": true,
    "zenMode.hideStatusBar": true,
    "zenMode.hideLineNumbers": true,
    "zenMode.centerLayout": true,
    "zenMode.restore": true,
    "zenMode.showTabs": "none",
    "zenMode.silentNotifications": true,
    
    // Custom Token and Color Customizations for Everforest
    "editor.tokenColorCustomizations": {
        "[Everforest*]": {
            "textMateRules": [
                {
                    "scope": [
                        "comment",
                        "punctuation.definition.comment"
                    ],
                    "settings": {
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": [
                        "keyword",
                        "storage.type",
                        "storage.modifier"
                    ],
                    "settings": {
                        "fontStyle": "italic"
                    }
                }
            ]
        }
    }
}
