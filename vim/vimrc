\}

let g:ale_fixers = {
\   '*': ['remove_trailing_lines', 'trim_whitespace'],
\   'typescript': ['prettier', 'eslint'],
\   'typescriptreact': ['prettier', 'eslint'],
\   'javascript': ['prettier', 'eslint'],
\   'javascriptreact': ['prettier', 'eslint'],
\   'yaml': ['prettier'],
\   'terraform': ['terraform'],
\   'sh': ['shfmt'],
\   'json': ['prettier', 'jq'],
\}

let g:ale_lint_on_enter = 1             " Lint when opening a file
let g:ale_lint_on_save = 1              " Lint on save
let g:ale_lint_on_text_changed = 'normal' " Lint as you navigate
let g:ale_lint_delay = 500              " Wait 500ms after typing stops
let g:ale_fix_on_save = 0               " DON'T auto-fix (review first!)
let g:ale_sign_error = '✖'
let g:ale_sign_warning = '⚠'
let g:ale_sign_info = 'ℹ'
let g:ale_echo_msg_format = '[%linter%] %s [%severity%]'
let g:ale_floating_preview = 1          " Use floating window for details
let g:ale_detail_to_floating_preview = 1
let g:ale_virtualtext_cursor = 'current' " Show error inline at cursor

" ALE Navigation — Jump between lint errors
nmap <silent> ]e <Plug>(ale_next_wrap)
nmap <silent> [e <Plug>(ale_previous_wrap)

" ALE Actions
nmap <silent> <leader>ed <Plug>(ale_detail)      " Show error detail
nmap <silent> <leader>af :ALEFix<CR>              " Auto-fix current file
nmap <silent> <leader>at :ALEToggle<CR>           " Toggle ALE on/off
nmap <silent> <leader>el :ALEPopulateQuickfix<CR>:copen<CR> " All errors → quickfix

" --- 7. LANGUAGE SERVER (CoC.nvim) INTEGRATION ---
" CoC handles LSP (go-to-definition, type checking, hover docs)
" ALE handles linting (eslint, shellcheck, yamllint, tflint)
" They work together without conflict.
let g:coc_global_extensions = [
\   'coc-yaml',
\   'coc-tsserver',
\   'coc-json',
\   'coc-sh',
\]

" Tab for Autocomplete & Navigation
inoremap <silent><expr> <TAB>
      \ coc#pum#visible() ? coc#pum#next(1) :
      \ CheckBackspace() ? "\<Tab>" :
      \ coc#refresh()
inoremap <expr><S-TAB> coc#pum#visible() ? coc#pum#prev(1) : "\<C-h>"

function! CheckBackspace() abort
  let col = col('.') - 1
  return !col || getline('.')[col - 1]  =~# '\s'
endfunction

" Enter to confirm autocomplete selection
inoremap <silent><expr> <CR> coc#pum#visible() ? coc#pum#confirm()
                              \: "\<C-g>u\<CR>\<c-r>=coc#on_enter()\<CR>"

" Jump between diagnostics/errors
nmap <silent> [g <Plug>(coc-diagnostic-prev)
nmap <silent> ]g <Plug>(coc-diagnostic-next)

" GoTo Code Navigation (LSP)
nmap <silent> gd <Plug>(coc-definition)
nmap <silent> gy <Plug>(coc-type-definition)
nmap <silent> gi <Plug>(coc-implementation)
nmap <silent> gr <Plug>(coc-references)

" Show documentation when pressing 'K'
nnoremap <silent> K :call ShowDocumentation()<CR>
function! ShowDocumentation()
  if CocAction('hasProvider', 'hover')
    call CocActionAsync('doHover')
  else
    call feedkeys('K', 'in')
  endif
endfunction

" Auto-format YAML files on save
autocmd BufWritePre *.yml,*.yaml silent! call CocAction('format')

" Highlight symbol under cursor on CursorHold
autocmd CursorHold * silent call CocActionAsync('highlight')

xmap <leader>f  <Plug>(coc-format-selected)
nmap <leader>f  <Plug>(coc-format-selected)

" --- 8. TERRAFORM INTEGRATION ---
let g:terraform_fmt_on_save = 0         " Don't auto-format (review first)
let g:terraform_align = 1              " Align = signs in HCL

nmap <silent> <leader>tv :!terraform validate<CR>
nmap <silent> <leader>tf :!terraform fmt %<CR>:e<CR>
nmap <silent> <leader>tp :!terraform plan -no-color \| head -100<CR>

" --- 9. AI CODE REVIEW MODE KEYBINDINGS ---
" Structured review workflows for AI-generated code.

" ── Quick Review Mode ────────────────────────────────────────────
" Open only changed files, fold unchanged, jump between errors
nmap <silent> <leader>rs :GFiles?<CR>           " Review: show changed files
nmap <silent> <leader>rf :GitGutterFold<CR>     " Review: fold unchanged lines
nmap <silent> <leader>re :ALEPopulateQuickfix<CR>:copen<CR> " Review: all errors

" ── Diff Review Mode ─────────────────────────────────────────────
nmap <silent> <leader>rd :Gdiffsplit<CR>        " Diff against HEAD
nmap <silent> <leader>rm :Gdiffsplit main<CR>   " Diff against main branch
