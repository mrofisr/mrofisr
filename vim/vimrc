nmap <silent> <leader>aF :ALEFix<CR>:sleep 500m<CR>:ALELint<CR> " Fix + re-lint

" ── Misc Review Helpers ──────────────────────────────────────────
nmap <silent> <leader>u :UndotreeToggle<CR>     " Visual undo tree
nmap <silent> <leader><space> :nohlsearch<CR>   " Clear search highlight

" --- 10. INDENTLINE & VISUAL SETTINGS ---
let g:indentLine_char = '│'
let g:indentLine_enabled = 1

" Highlighted yank duration
let g:highlightedyank_highlight_duration = 300

" --- 11. FILETYPE-SPECIFIC SETTINGS ---
augroup ai_review_filetypes
    autocmd!
    " YAML: show column guide for alignment
    autocmd FileType yaml setlocal cursorcolumn
    " Shell: 4-space indent
    autocmd FileType sh,bash setlocal tabstop=4 shiftwidth=4
