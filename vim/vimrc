" --- 7. CUSTOM WELCOMING DASHBOARD & KEYBINDINGS MEMO ---
function! s:center(text)
  let l:pad = (&columns - strwidth(a:text)) / 2
  return l:pad > 0 ? repeat(' ', l:pad) . a:text : a:text
endfunction

function! StartScreen()
  " Only run if Vim is started with no arguments/files, or if we are re-drawing the dashboard
  if &filetype != 'startup'
    if argc() != 0 || line('$') > 1 || getline(1) != '' || &modified
      return
    endif
  endif

  " Create a new buffer or use the current one
  if &filetype != 'startup'
    enew
  endif

  setlocal buftype=nofile
  setlocal bufhidden=wipe
  setlocal noswapfile
  setlocal nobuflisted
  setlocal nonumber
  setlocal norelativenumber
  setlocal nocursorline
  setlocal signcolumn=no
  setlocal foldcolumn=0
  setlocal statusline=\ Premium\ IDE\ Startup\ 

  let l:username = $USER
  if empty(l:username)
    let l:username = 'Developer'
  endif

  " Calculate margins for responsive centering
  let l:width = 62
  let l:margin = (&columns - l:width) / 2
  if l:margin < 0
    let l:margin = 0
  endif
  let l:pad = repeat(' ', l:margin)

  let l:lines = []
  call add(l:lines, '')
  call add(l:lines, s:center('      _   _ _____ ___  ____  ____        _     _ '))
  call add(l:lines, s:center('     | \ | | ____/ _ \|  _ \|  _ \      / \   | |'))
  call add(l:lines, s:center('     |  \| |  _|| | | | |_) | |_) |    / _ \  | |'))
  call add(l:lines, s:center('     | |\  | |__| |_| |  _ <|  _ <    / ___ \ | |'))
  call add(l:lines, s:center('     |_| \_|_____\___/|_| \_\_| \_\  /_/   \_\|_|'))
  call add(l:lines, '')
  call add(l:lines, s:center('      Classic Vim 9.0 • AI Code Review Workstation'))
  call add(l:lines, s:center('               Welcome back, ' . l:username . '!'))
  call add(l:lines, '')
  call add(l:lines, s:center('  [i] New File       [p] Fuzzy Find (FZF)   [f] Explorer       [q] Quit'))
  call add(l:lines, '')
  call add(l:lines, l:pad . '  ⚡ GENERAL & WINDOW NAVIGATION')
  call add(l:lines, l:pad . '  ──────────────────────────────────────────────────────────')
  call add(l:lines, l:pad . '  <Space> h      : Clear Search Highlights')
  call add(l:lines, l:pad . '  Ctrl + h/j/k/l : Navigate Split Windows')
  call add(l:lines, '')
  call add(l:lines, l:pad . '  📂 FILE EXPLORER & FUZZY SEARCH (FZF & Ripgrep)')
  call add(l:lines, l:pad . '  ──────────────────────────────────────────────────────────')
  call add(l:lines, l:pad . '  Ctrl + n       : Toggle NERDTree sidebar')
  call add(l:lines, l:pad . '  <Space> nf     : Find current file in NERDTree')
  call add(l:lines, l:pad . '  Ctrl + p       : Blazing-fast File Search (FZF)')
  call add(l:lines, l:pad . '  <Space> pf     : Fuzzy find files (FZF)')
  call add(l:lines, l:pad . '  <Space> pb     : Fuzzy find open buffers (FZF)')
  call add(l:lines, l:pad . '  <Space> pr     : Interactive text search in files (Ripgrep)')
  call add(l:lines, l:pad . '  <Space> rg     : Search word under cursor (Ripgrep)')
  call add(l:lines, '')
  call add(l:lines, l:pad . '  \U0001f50d AI CODE REVIEW WORKFLOW')
  call add(l:lines, l:pad . '  ──────────────────────────────────────────────────────────')
  call add(l:lines, l:pad . '  <Space> rs     : Start Review (show changed files)')
  call add(l:lines, l:pad . '  <Space> rf     : Fold unchanged (show ONLY diffs)')
  call add(l:lines, l:pad . '  <Space> re     : All lint errors -> quickfix')
  call add(l:lines, l:pad . '  <Space> rd     : Side-by-side diff vs HEAD')
  call add(l:lines, l:pad . '  <Space> rm     : Side-by-side diff vs main')
  call add(l:lines, l:pad . '  <Space> rc     : Close diff view')
  call add(l:lines, '')
  call add(l:lines, l:pad . '  \ue725 GIT HUNK REVIEW (Accept/Reject AI Changes)')
  call add(l:lines, l:pad . '  ──────────────────────────────────────────────────────────')
  call add(l:lines, l:pad . '  ]c / [c        : Next / Prev changed hunk')
  call add(l:lines, l:pad . '  <Space> hp     : Preview hunk change')
  call add(l:lines, l:pad . '  <Space> hs     : Accept (stage) hunk')
  call add(l:lines, l:pad . '  <Space> hu     : Reject (revert) hunk')
  call add(l:lines, l:pad . '  <Space> hf     : Fold unchanged (show only AI changes)')
  call add(l:lines, '')
  call add(l:lines, l:pad . '  ⚡ LINTING (ALE) — Catches AI Mistakes')
  call add(l:lines, l:pad . '  ──────────────────────────────────────────────────────────')
  call add(l:lines, l:pad . '  ]e / [e        : Next / Prev lint error')
  call add(l:lines, l:pad . '  <Space> ed     : Show error detail')
  call add(l:lines, l:pad . '  <Space> af     : Auto-fix current file')
  call add(l:lines, l:pad . '  <Space> el     : All errors -> quickfix list')
  call add(l:lines, l:pad . '  <Space> at     : Toggle ALE on/off')
  call add(l:lines, '')
  call add(l:lines, l:pad . '  🛠 LSP / IDE FEATURES (CoC.nvim)')
  call add(l:lines, l:pad . '  ──────────────────────────────────────────────────────────')
  call add(l:lines, l:pad . '  gd / gy        : Go to Definition / Type Definition')
  call add(l:lines, l:pad . '  gi / gr        : Go to Implementation / References')
  call add(l:lines, l:pad . '  K              : Show Documentation / Hover doc')
  call add(l:lines, l:pad . '  [g / ]g        : Prev / Next Diagnostic (Error)')
  call add(l:lines, l:pad . '  <Space> f      : Format selected code / buffer')
  call add(l:lines, '')
  call add(l:lines, l:pad . '  🏗 TERRAFORM')
  call add(l:lines, l:pad . '  ──────────────────────────────────────────────────────────')
  call add(l:lines, l:pad . '  <Space> tv     : terraform validate')
  call add(l:lines, l:pad . '  <Space> tf     : terraform fmt')
  call add(l:lines, l:pad . '  <Space> tp     : terraform plan (preview)')
  call add(l:lines, '')

  " Render lines
  setlocal modifiable
  silent %delete _
  call setline(1, l:lines)
  setlocal nomodifiable
  setlocal nomodified

  " Keybindings inside the start screen buffer
  nnoremap <buffer> <silent> e :enew<CR>
  nnoremap <buffer> <silent> i :enew <bar> startinsert<CR>
  nnoremap <buffer> <silent> a :enew <bar> startinsert<CR>
  nnoremap <buffer> <silent> o :enew <bar> startinsert<CR>
  if executable('fzf')
    nnoremap <buffer> <silent> p :Files<CR>
  else
    nnoremap <buffer> <silent> p :CtrlP<CR>
  endif
  nnoremap <buffer> <silent> f :NERDTreeToggle<CR>
  nnoremap <buffer> <silent> q :q<CR>

  " Syntax highlighting for startup screen
  setlocal filetype=startup
  syntax match StartupLogo /\%>1l\%<7l.*/
  syntax match StartupTitle /\%7l.*/
  syntax match StartupWelcome /\%8l.*/
  syntax match StartupShortcut /\[[a-z]\]/
  syntax match StartupGroup /^\s*\(⚡\|📂\|\|🛠\).*/
  syntax match StartupKey /^\s*[^:]*\ze:/
  syntax match StartupSeparator /───*/

  highlight default link StartupLogo String
  highlight default link StartupTitle Title
  highlight default link StartupWelcome Identifier
  highlight default link StartupShortcut Special
  highlight default link StartupGroup Type
  highlight default link StartupKey Function
  highlight default link StartupSeparator Comment
endfunction

autocmd VimEnter * call StartScreen()
autocmd VimResized * if &filetype == 'startup' | call StartScreen() | endif
