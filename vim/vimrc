" ==============================================================================
"               POWERFUL, IDE-LIKE CLASSIC VIM 9.0 CONFIGURATION
"         Optimized for YAML Development & AI-Assisted Code Reviews
" ==============================================================================

" --- 1. PLUGIN MANAGER (vim-plug) ---
call plug#begin('~/.vim/plugged')

" UI & Aesthetics
Plug 'dracula/vim', { 'as': 'dracula' } " Famous high-contrast Dracula dark theme
Plug 'joshdick/onedark.vim'            " Premium dark color scheme
Plug 'sainnhe/everforest'               " Super comfortable, warm forest theme
Plug 'morhetz/gruvbox'                  " Premium retro groove theme
Plug 'vim-airline/vim-airline'          " Beautiful, status line
Plug 'vim-airline/vim-airline-themes'   " Airline themes
Plug 'ryanoasis/vim-devicons'           " File icons (requires Nerd Font)

" Navigation & Search
Plug 'preservim/nerdtree'               " Sidebar file explorer
Plug 'ctrlpvim/ctrlp.vim'               " Simple, lightweight fuzzy finder
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'                 " Premium, blazing-fast fuzzy finder

" Code Editing Utilities
Plug 'tpope/vim-commentary'             " Comment/uncomment with `gc` / `gcc`
Plug 'tpope/vim-surround'               " Manipulate surrounds: quotes, parens, tags
Plug 'tpope/vim-repeat'                 " Allow repeating plugin maps with `.`

" Git Integration & AI Code Review Tools
Plug 'tpope/vim-fugitive'               " Ultimate Git integration (Gdiffsplit, Gstatus)
Plug 'airblade/vim-gitgutter'           " Git diff signs in gutter & hunk staging

" Language Server Protocol (LSP) & IDE features
Plug 'neoclide/coc.nvim', {'branch': 'release'} " VS Code-like LSP features
Plug 'stephpy/vim-yaml'                 " Improved YAML syntax highlighting

" Async Linting Engine (wires CLI linters into Vim)
Plug 'dense-analysis/ale'               " Inline linting: eslint, shellcheck, tflint, yamllint

" Additional Language Support for AI Code Review
Plug 'hashivim/vim-terraform'           " Terraform syntax, fmt, validate
Plug 'leafgarland/typescript-vim'       " TypeScript syntax highlighting
Plug 'pangloss/vim-javascript'          " Enhanced JavaScript syntax
Plug 'maxmellon/vim-jsx-pretty'         " JSX/TSX syntax support

" Diff & Review Enhancement
Plug 'rickhowe/diffchar.vim'            " Character-level diff highlighting
Plug 'mbbill/undotree'                  " Visual undo history tree
Plug 'machakann/vim-highlightedyank'    " Briefly highlight yanked text
Plug 'Yggdroot/indentLine'              " Show indentation guides

call plug#end()

" --- 2. GENERAL EDITOR SETTINGS ---
syntax on                               " Enable syntax highlighting
filetype plugin indent on               " Enable filetype plugins and auto-indenting

set number                              " Show absolute line number of current line
set relativenumber                      " Show relative line numbers for quick jumping
set cursorline                          " Highlight the current line
set signcolumn=yes                      " Always show sign column (prevents flashing)
set updatetime=300                      " Fast update interval (for GitGutter and CoC)
set mouse=a                             " Enable mouse support in all modes
set encoding=utf-8                      " Set default file encoding to UTF-8
set hlsearch                            " Highlight all matches of the search pattern
set incsearch                           " Show search matches dynamically as you type
set ignorecase                          " Case-insensitive searching...
set smartcase                           " ...unless search term contains uppercase letters
set wildmenu                            " Visual autocomplete menu for command-line mode
set splitright                          " Open new vertical splits on the right
set splitbelow                          " Open new horizontal splits below
set hidden                              " Allow switching away from unsaved buffers
set cmdheight=1                         " Set command bar height to 1 line
set backspace=indent,eol,start          " Make backspace behave normally
set scrolloff=8                         " Keep 8 lines visible above/below cursor
set sidescrolloff=8                     " Keep 8 columns visible left/right
set colorcolumn=80,120                  " Show column guides at 80 and 120
set nowrap                              " Don't wrap long lines (see full context)
set list                                " Show invisible characters
set listchars=tab:→\ ,trail:·,extends:»,precedes:«,nbsp:␣

" Indentation Rules (Sensible defaults, optimized for YAML)
set expandtab                           " Convert tabs to spaces
set tabstop=2                           " Width of tab character
set shiftwidth=2                        " Width of auto-indents
set softtabstop=2                       " Tab key inserts 2 spaces
set autoindent                          " Copy indent from current line when starting a new line
set smartindent                         " Smart auto-indenting for code structures

" Persistent undo (review history across sessions)
set undofile
set undodir=~/.vim/undodir
silent !mkdir -p ~/.vim/undodir

" CoC.nvim Compatibility Settings
set nobackup                            " Some servers have issues with backup files
set nowritebackup

" --- 3. THEME & VISUAL CUSTOMIZATION ---
" Enable 24-bit True Colors (if supported by terminal)
if (has("termguicolors"))
  set termguicolors
endif

" Correct RGB escape codes for true color in classic Vim under tmux/screen
if !has('nvim') && &term =~# '^screen\|^tmux\|^xterm'
  let &t_8f = "\<Esc>[38;2;%lu;%lu;%lum"
  let &t_8b = "\<Esc>[48;2;%lu;%lu;%lum"
endif

" Premium Everforest Dark Theme Configuration
set background=dark                     " Use dark background

" Everforest options for maximum eye comfort
let g:everforest_background = 'medium'  " 'hard', 'medium' or 'soft'
let g:everforest_enable_italic = 1      " Enable italics
let g:everforest_better_performance = 1 " Fast loading

try
  colorscheme everforest                  " Activate Everforest theme
  let g:airline_theme='everforest'        " Set Airline to match
catch
  " Fallback if Everforest is not yet installed
  colorscheme desert
endtry
let g:airline_powerline_fonts = 1       " Use Powerline/Nerd Font symbols in statusline

" --- 4. KEY BINDINGS & SHORTCUTS ---
let mapleader = " "                     " Set Leader key to Space

" Clear search highlights quickly
nnoremap <leader>h :nohlsearch<CR>

" Window Navigation (Move between splits using Ctrl + h/j/k/l)
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" NERDTree Sidebar Explorer
nnoremap <C-n> :NERDTreeToggle<CR>
nnoremap <leader>nf :NERDTreeFind<CR>    " Find current file in the NERDTree hierarchy

" --- FZF & CtrlP Fuzzy Search ---
" Speed up CtrlP using ripgrep if available (fallback)
if executable('rg')
  let g:ctrlp_user_command = 'rg %s --files --hidden --color=never --glob "!.git"'
  let g:ctrlp_use_caching = 0
endif

" FZF Fuzzy Finder Configurations
if executable('fzf')
  " Use FZF for file searching by default (replaces CtrlP with blazing-fast FZF)
  let g:ctrlp_map = '' " Disable default CtrlP mapping to avoid conflicts
  nnoremap <C-p> :Files<CR>
  
  " Useful FZF bindings
  nnoremap <leader>pf :Files<CR>          " Search files in project
  nnoremap <leader>pb :Buffers<CR>        " Search open buffers
  nnoremap <leader>pr :Rg<CR>             " Search text inside files (ripgrep)
  nnoremap <leader>ph :History<CR>        " Search recently opened files (MRU)
  nnoremap <leader>pc :Commits<CR>        " Search git commits
else
  let g:ctrlp_map = '<C-p>'
endif

" Ripgrep (rg) Built-in Integration
if executable('rg')
  " Use ripgrep as standard grep tool for classic Vim commands
  set grepprg=rg\ --vimgrep\ --no-heading\ --smart-case
  set grepformat=%f:%l:%c:%m
  
  " Search word under cursor instantly in project and open quickfix
  nnoremap <leader>rg :grep! "\b<C-r><C-w>\b"<CR>:copen<CR>
endif

" --- 5. AI CODE REVIEW & GIT WORKFLOWS ---
" Key mappings for Git operations
nnoremap <leader>gs :Git<CR>            " Open interactive Git Status window (Gstatus)
nnoremap <leader>gd :Gdiffsplit<CR>     " Open side-by-side Git Diff view (Gdiffsplit)
nnoremap <leader>gD :Gdiffsplit main<CR> " Diff against main branch
nnoremap <leader>gb :Git blame<CR>       " Open Git Blame sidebar
nnoremap <leader>gl :Git log --oneline -20 %<CR> " Git log for current file

" GitGutter hunk navigation and actions (Review AI code hunks)
let g:gitgutter_sign_added = '▎'
let g:gitgutter_sign_modified = '▎'
let g:gitgutter_sign_removed = '▁'
let g:gitgutter_sign_removed_first_line = '▔'
let g:gitgutter_sign_modified_removed = '▎'
let g:gitgutter_map_keys = 0            " Disable defaults, use our own

nmap ]c <Plug>(GitGutterNextHunk)       " Jump to next AI change hunk
nmap [c <Plug>(GitGutterPrevHunk)       " Jump to previous AI change hunk

" Interactive Hunk Staging and Reverting
nmap <leader>hp <Plug>(GitGutterPreviewHunk) " Preview the AI changes at current line
nmap <leader>hs <Plug>(GitGutterStageHunk)   " Stage (accept) this AI change hunk
nmap <leader>hu <Plug>(GitGutterUndoHunk)    " Revert (discard) this AI change hunk

" KILLER FEATURE: Fold unchanged lines — show ONLY what AI changed
nmap <leader>hf :GitGutterFold<CR>

